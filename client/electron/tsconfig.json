{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "outDir": "../electron-dist",
    "rootDir": ".",
    "strict": true,
    "typeRoots": ["../node_modules/@types"],
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["./**/*.ts"]
}
