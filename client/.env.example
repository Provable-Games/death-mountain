# VRF Provider (Pragma)
VITE_PUBLIC_VRF_PROVIDER_ADDRESS=

# Cloudflare Stream (video player)
VITE_PUBLIC_CLOUDFLARE_ID=

# PostHog Analytics
VITE_PUBLIC_POSTHOG_HOST=
VITE_PUBLIC_POSTHOG_KEY=

# Onramper (fiat-to-crypto widget)
# Get your API key at https://onramper.com
# Test keys start with pk_test_, prod keys with pk_prod_
VITE_ONRAMPER_API_KEY=

# Debug flags
VITE_ENABLE_GEAR_LOGS=false

# Feature flags
VITE_ENABLE_ENTER_DUNGEON=false
